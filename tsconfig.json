{
  "compilerOptions": {
    "module": "nodenext",
    "target": "esnext",
    "lib": ["ESNext"],
    "paths": {
      "@/*": ["./src/*"],
    },
    "strict": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
  }
}
